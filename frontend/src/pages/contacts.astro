---
import MainLayout from '../layouts/MainLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ContactButtons from '../components/ContactButtons.astro';
import WriteToUs from '../components/WriteToUs.astro';
import IconBox from '../components/ui/icon-box.astro';
import { Mail, Phone, MapPin } from '@lucide/astro';

---


<MainLayout title="Контакты | Змеиный лес">
  <SiteHeader slot="header" />

  <main class="pt-32 pb-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-serif font-bold text-brand-text mb-12 tracking-tight">
        Контакты
      </h1>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="space-y-12">
          <section>
            <h2 class="text-brand-text/40 text-sm uppercase tracking-widest mb-6">Свяжитесь с нами</h2>
            <div class="space-y-6">
              <div class="flex items-center gap-6">
                <IconBox>
                  <Phone class="w-6 h-6" />
                </IconBox>
                <div>
                  <p class="text-brand-text/60 text-sm">Телефон</p>
                  <a href="tel:+79950780698" class="text-xl font-bold text-brand-text hover:text-brand-accent transition-colors">+7 (995) 078-06-98</a>
                </div>
              </div>

              <div class="flex items-center gap-6">
                <IconBox>
                  <Mail class="w-6 h-6" />
                </IconBox>
                <div>
                  <p class="text-brand-text/60 text-sm">Email</p>
                  <a href="mailto:margoscar019@gmail.com" class="text-xl font-bold text-brand-text hover:text-brand-accent transition-colors">margoscar019@gmail.com</a>
                </div>
              </div>
            </div>
          </section>

          <section>
            <h2 class="text-brand-text/40 text-sm uppercase tracking-widest mb-6">Наш адрес</h2>
            <div class="space-y-6">
              <div class="flex items-start gap-6">
                <IconBox>
                  <MapPin class="w-6 h-6" />
                </IconBox>
                <div>
                  <p class="text-brand-text/60 text-sm">Местоположение</p>
                  <p class="text-xl font-bold text-brand-text">г. Красноярск, ул. Октябрьская, д. 10Б</p>
                </div>
              </div>
            </div>
          </section>

          <section>
            <h2 class="text-brand-text/40 text-sm uppercase tracking-widest mb-6">Социальные сети</h2>
            <ContactButtons variant="secondary" className="justify-start" />
          </section>
        </div>

        <WriteToUs />
      </div>
    </div>
  </main>

  <SiteFooter slot="footer" />
</MainLayout>
