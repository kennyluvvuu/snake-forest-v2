---
import MainLayout from '../../layouts/MainLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ProductCard from '../../components/ProductCard.astro';
import { apiFetch, type Product } from '@/lib/api.ts';

let products: Product[] = [];
let error = null;

try {
  products = await apiFetch<Product[]>('/products/');
} catch (e) {
  console.error("Failed to fetch products catalog:", e);
  error = "Не удалось загрузить каталог товаров";
}

const tabs = [
  { id: 'all', label: 'Все товары' },
  { id: 'usable', label: 'Оборудование' },
  { id: 'food', label: 'Корм' },
  { id: 'toy', label: 'Игрушки' }
];
---

<MainLayout title="Магазин товаров | Змеиный лес">
  <SiteHeader slot="header" />

  <section class="max-w-7xl mx-auto px-4 py-24">
    <div class="mb-16">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-12">
        <div>
          <h1 class="text-5xl md:text-7xl font-serif font-black text-brand-text mb-4">Магазин</h1>
          <div class="h-1.5 w-24 bg-brand-accent organic-shape-2"></div>
        </div>
        
        <!-- Tabs -->
        <div class="overflow-x-auto pb-2 scrollbar-hide">
          <div class="flex gap-2 p-1.5 bg-brand-surface rounded-[2rem] border border-brand-border w-max shadow-inner" id="filter-container">
            {tabs.map(tab => (
              <button 
                data-filter={tab.id}
                class={`px-8 py-3 rounded-xl text-xs font-black uppercase tracking-[0.2em] transition-all cursor-pointer ${tab.id === 'all' ? 'bg-brand-bg text-brand-text shadow-md' : 'text-brand-text/40 hover:text-brand-text'}`}
              >
                {tab.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    {error ? (
      <div class="bg-brand-surface p-20 organic-shape-1 border border-brand-border text-center shadow-inner">
        <p class="text-brand-text/40 italic font-serif text-2xl">{error}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 md:gap-10">
        {products.length > 0 ? (
          products.map((product, i) => (
            <div class="filter-item animate-serpentine" data-type={product.type} style={`animation-delay: ${i * 50}ms`}>
              <ProductCard product={product} />
            </div>
          ))
        ) : (
          <p class="col-span-full text-center text-brand-text/40 py-32 font-serif italic text-3xl">В данный момент каталог товаров пуст</p>
        )}
      </div>
    )}
    
    <div class="mt-32 bg-jungle-deep text-brand-bg organic-shape-1 p-12 md:p-24 text-center relative overflow-hidden shadow-2xl">
      <div class="relative z-10">
        <h2 class="text-4xl md:text-6xl font-serif font-black mb-8 leading-tight">Не нашли что искали?</h2>
        <p class="text-brand-bg/60 text-xl mb-12 max-w-2xl mx-auto font-light leading-relaxed">
          Мы можем привезти оборудование и корма под заказ или изготовить уникальные 3D-изделия по вашим размерам.
        </p>
        <a 
          href={import.meta.env.PUBLIC_TG_LINK}
          class="inline-block px-12 py-5 bg-brand-accent text-brand-text organic-shape-2 font-black uppercase tracking-[0.2em] text-xs transition-all hover:scale-110 active:scale-95 hover:shadow-2xl hover:shadow-brand-accent/30"
        >
          Написать нам
        </a>
      </div>
      <!-- Background Accents -->
      <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-brand-accent/10 rounded-full blur-[100px]"></div>
    </div>
  </section>

  <SiteFooter slot="footer" />

  <script>
    import { initFilter } from '@/scripts/filter.ts';

    initFilter({
      filterContainerSelector: '#filter-container',
      itemSelector: '.filter-item',
      itemDataKey: 'type',
      activeClasses: ['bg-brand-bg', 'text-brand-text', 'shadow-md'],
      inactiveClasses: ['text-brand-text/40'],
    });
  </script>
</MainLayout>
