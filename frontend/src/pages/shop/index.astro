---
import MainLayout from '../../layouts/MainLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ProductCard from '../../components/ProductCard.astro';
import { apiFetch, type Product } from '@/lib/api.ts';

let products: Product[] = [];
let error = null;

try {
  products = await apiFetch<Product[]>('/products/');
} catch (e) {
  console.error("Failed to fetch products catalog:", e);
  error = "Не удалось загрузить каталог товаров";
}

const tabs = [
  { id: 'all', label: 'Все товары' },
  { id: 'usable', label: 'Оборудование' },
  { id: 'food', label: 'Корм' },
  { id: 'toy', label: 'Игрушки' }
];
---

<MainLayout title="Магазин товаров | Змеиный лес">
  <SiteHeader slot="header" />

  <section class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-text mb-8">Магазин</h1>
      
      <!-- Tabs -->
      <div class="overflow-x-auto">
        <div class="flex gap-1 p-1 bg-brand-surface rounded-2xl border border-brand-border w-max" id="filter-container">
          {tabs.map(tab => (
            <button 
              data-filter={tab.id}
              class={`px-6 py-2 rounded-xl text-sm font-bold transition-all ${tab.id === 'all' ? 'bg-brand-bg text-brand-text shadow-sm' : 'text-brand-text/50 hover:text-brand-text'}`}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    {error ? (
      <div class="bg-brand-surface p-12 rounded-3xl border border-brand-border text-center">
        <p class="text-brand-text/60 italic">{error}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 md:gap-8">
        {products.length > 0 ? (
          products.map(product => (
            <div class="filter-item" data-type={product.type}>
              <ProductCard product={product} />
            </div>
          ))
        ) : (
          <p class="col-span-full text-center text-brand-text/40 py-20">В данный момент каталог товаров пуст</p>
        )}
      </div>
    )}
    
    <div class="mt-20 bg-brand-accent/10 border border-brand-accent/20 rounded-3xl p-8 md:p-12 text-center">
      <h2 class="text-2xl font-serif font-bold text-brand-text mb-4">Не нашли что искали?</h2>
      <p class="text-brand-text/60 mb-8 max-w-xl mx-auto">
        Мы можем привезти оборудование и корма под заказ или изготовить уникальные 3D-изделия по вашим размерам.
      </p>
      <a 
        href={import.meta.env.PUBLIC_TG_LINK}
        class="inline-block px-10 py-4 bg-brand-text text-brand-bg rounded-xl font-bold transition-transform hover:scale-105 active:scale-95"
      >
        Написать нам
      </a>
    </div>
  </section>

  <SiteFooter slot="footer" />

  <script>
    import { initFilter } from '@/scripts/filter.ts';

    initFilter({
      filterContainerSelector: '#filter-container',
      itemSelector: '.filter-item',
      itemDataKey: 'type',
      activeClasses: ['bg-brand-bg', 'text-brand-text', 'shadow-sm'],
      inactiveClasses: ['text-brand-text/50'],
    });
  </script>
</MainLayout>
