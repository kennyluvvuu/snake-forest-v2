---
import MainLayout from '../layouts/MainLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import AnimalCard from '../components/AnimalCard.astro';
import ShopCategoryCard from '../components/ShopCategoryCard.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { apiFetch, type Animal } from '@/lib/api.ts';

let latestAnimals: Animal[] = [];
let error = null;

try {
  const animals = await apiFetch<Animal[]>('/animals/');
  latestAnimals = animals.slice(0, 3);
} catch (e) {
  console.error("Failed to fetch animals for home page:", e);
  error = "Не удалось загрузить данные";
}

const shopCategories = [
  {
    title: "Оборудование",
    description: "Лампы, термостаты, поилки, укрытия и 3D-декор",
    image: "https://sun9-39.userapi.com/s/v1/ig2/KHtyaTB0z4AJY5jCzHQaac1-23oVCHN13ogXfFGAn4avUmgD-ElTu4kGUcBR9OfHfSluR04Z9feECSETqJ8KR7Nc.jpg?quality=95&as=32x43,48x64,72x96,108x144,160x213,240x320,360x480,480x640,540x720,640x853,720x960,960x1280&from=bu&cs=960x0",
    href: "/shop?type=usable"
  },
  {
    title: "Корм",
    description: "Замороженные и живые корма для всех видов",
    image: "https://content.onliner.by/fleamarket/941535/800x800/11bf5dd7a754fba5fe52767fd730e83a.jpg",
    href: "/shop?type=food"
  },
  {
    title: "Игрушки",
    description: "Когда хочется развлечь не только питомцев",
    image: "https://cdn.thingiverse.com/assets/ed/91/ca/d5/52/2b2c5d7f-141f-4e19-bf04-b7429bd0fb99.webp",
    href: "/shop?type=toy"
  }
];
---

<MainLayout>
  <SiteHeader slot="header" />

  <section class="relative pt-24 pb-20 md:pt-48 md:pb-40 px-4 overflow-hidden flex items-center justify-center min-h-[70vh]">
    <!-- Background Content -->
    <div class="absolute inset-0 z-0 select-none pointer-events-none">
      <img
        src="index_hero.jpg"
        alt="Forest Background"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <!-- Glassmorphic Overlay for Readability -->
      <div class="absolute inset-0 bg-brand-bg/70 backdrop-blur-[1px]"></div>
      <!-- Vignette and Gradient for depth -->
      <div class="absolute inset-0 bg-gradient-to-b from-brand-bg/30 via-transparent to-brand-bg"></div>
    </div>

    <div class="max-w-7xl mx-auto text-center relative z-10 animate-serpentine">
      <h1 class="text-7xl md:text-9xl font-serif font-black text-brand-text mb-6 tracking-tight drop-shadow-sm">
        Змеиный лес
      </h1>
      <p class="text-2xl md:text-2xl text-brand-text/80 mb-12 max-w-2xl mx-auto leading-relaxed font-light">
        Кураторская коллекция редких рептилий и профессиональное оборудование для создания <span class="font-semibold text-brand-text">биотопа мечты</span>.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="/animals" class="bg-brand-text text-brand-bg px-12 py-5 organic-shape-1 font-bold text-xl transition-all hover:scale-105 hover:bg-jungle-deep hover:shadow-2xl active:scale-95">
          Животные
        </a>
        <a href="/shop" class="bg-brand-surface/80 backdrop-blur-md text-brand-text border border-brand-border px-12 py-5 organic-shape-2 font-bold text-xl transition-all hover:scale-105 hover:shadow-2xl active:scale-95">
          Товары
        </a>
      </div>
    </div>
  </section>

  <section class="pt-24 pb-12 px-4 bg-brand-surface/30 relative overflow-hidden">
    <!-- Decorative vine/snake path placeholder -->
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-brand-accent/30 to-transparent"></div>

    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-16">
        <div>
          <h2 class="text-4xl md:text-5xl font-serif font-black text-brand-text mb-4">Новые жители</h2>
          <div class="h-1 w-20 bg-brand-accent rounded-full"></div>
        </div>
        <a href="/animals" class="hidden md:flex items-center gap-2 text-brand-text font-bold uppercase tracking-widest text-xs hover:text-brand-accent transition-colors group">
          Смотреть всех <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

      {error ? (
        <div class="bg-brand-surface p-12 organic-shape-1 border border-brand-border text-center shadow-inner">
          <p class="text-brand-text/60 italic">{error}</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          {latestAnimals.length > 0 ? (
            latestAnimals.map((animal, i) => (
              <div class="animate-serpentine" style={`animation-delay: ${i * 150}ms`}>
                <AnimalCard animal={animal} />
              </div>
            ))
          ) : (
            <p class="col-span-full text-center text-brand-text/40 py-20 font-serif italic text-2xl">Животных пока нет в продаже</p>
          )}
        </div>
      )}
    </div>
  </section>

  <section class="py-12 px-4 bg-jungle-deep text-brand-bg relative overflow-hidden">
    <!-- Background scale pattern -->
    <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: radial-gradient(var(--color-brand-accent) 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="max-w-2xl mb-16">
        <h2 class="text-4xl md:text-6xl font-serif font-black mb-6 leading-tight">Всё для <span class="text-brand-accent">совершенного</span> террариума</h2>
        <p class="text-brand-bg/60 text-lg md:text-xl font-light">От высокоточного климат-контроля до аутентичного декора из самого сердца джунглей.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-6 h-[800px] md:h-[600px]">
        <div class="md:col-span-2 md:row-span-2 relative group overflow-hidden organic-shape-1">
          <ShopCategoryCard {...shopCategories[0]} />
        </div>
        <div class="md:col-span-2 md:row-span-1 relative group overflow-hidden organic-shape-2">
          <ShopCategoryCard {...shopCategories[1]} />
        </div>
        <div class="md:col-span-2 md:row-span-1 relative group overflow-hidden rounded-[3rem]">
          <ShopCategoryCard {...shopCategories[2]} />
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 px-4">
    <div class="max-w-5xl mx-auto bg-brand-surface border border-brand-border organic-shape-1 p-12 md:p-24 text-center relative overflow-hidden shadow-2xl">
      <div class="relative z-10">
        <h2 class="text-4xl md:text-6xl font-serif font-black mb-8 text-brand-text">Нужна консультация?</h2>
        <p class="text-brand-text/70 text-xl mb-12 max-w-xl mx-auto font-light leading-relaxed">
          Наши эксперты помогут подобрать оборудование и дадут рекомендации по уходу за вашим новым питомцем.
        </p>
        <ContactButtons variant="primary" className="justify-center scale-110" />
      </div>
      <!-- Abstract Serpentine Shapes -->
      <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-teal-eye/10 rounded-full blur-[100px]"></div>
      <div class="absolute -top-20 -left-20 w-80 h-80 bg-brand-accent/10 rounded-full blur-[100px]"></div>
    </div>
  </section>

  <SiteFooter slot="footer" />
</MainLayout>
