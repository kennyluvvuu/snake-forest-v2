---
import MainLayout from '../layouts/MainLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ProductCard from '../components/ProductCard.astro';
import type { Product } from '../lib/api';

// Static placeholder products for now
const placeholders: Product[] = [
  {
    id: 'u1',
    name: 'Набор ламп для террариума (UVB 5.0 + Heat)',
    price: 3450,
    type: 'usable',
    preview: ['https://images.unsplash.com/photo-1629882495260-db32d19b1c99?q=80&w=600&auto=format&fit=crop'],
    description: 'Полный комплект освещения для средних террариумов.'
  },
  {
    id: 'f1',
    name: 'Замороженные мыши (голыши), 10 шт',
    price: 1200,
    type: 'food',
    preview: ['https://images.unsplash.com/photo-1594493309990-255d6447817a?q=80&w=600&auto=format&fit=crop'],
    description: 'Питательный корм для молодых змей и ящериц.'
  },
  {
    id: 't1',
    name: 'Интерактивная коряга-укрытие 3D',
    price: 2100,
    type: 'toy',
    preview: ['https://images.unsplash.com/photo-1623914017163-5477d64388cc?q=80&w=600&auto=format&fit=crop'],
    description: 'Красивое и функциональное укрытие из экологичного пластика.'
  },
  {
    id: 'u2',
    name: 'Термостат цифровой STC-1000',
    price: 4200,
    type: 'usable',
    preview: ['https://images.unsplash.com/photo-1585675100414-add2e465a136?q=80&w=600&auto=format&fit=crop'],
    description: 'Высокоточное управление температурой в вашем террариуме.'
  }
];

const tabs = [
  { id: 'all', label: 'Все товары' },
  { id: 'usable', label: 'Оборудование' },
  { id: 'food', label: 'Корм' },
  { id: 'toy', label: 'Игрушки' }
];
---

<MainLayout title="Магазин товаров | Змеиный лес">
  <SiteHeader slot="header" />

  <section class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-text mb-8">Магазин</h1>
      
      <!-- Tabs -->
      <div class="flex flex-wrap gap-1 p-1 bg-brand-surface rounded-2xl border border-brand-border inline-flex w-full md:w-auto" id="shop-tabs">
        {tabs.map(tab => (
          <button 
            data-tab={tab.id}
            class={`px-6 py-2 rounded-xl text-sm font-bold transition-all ${tab.id === 'all' ? 'bg-brand-bg text-brand-text shadow-sm' : 'text-brand-text/50 hover:text-brand-text'}`}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-8" id="product-grid">
      {placeholders.map(product => (
        <div class="product-item" data-type={product.type}>
          <ProductCard product={product} />
        </div>
      ))}
    </div>
    
    <div class="mt-20 bg-brand-accent/10 border border-brand-accent/20 rounded-3xl p-8 md:p-12 text-center">
      <h2 class="text-2xl font-serif font-bold text-brand-text mb-4">Не нашли что искали?</h2>
      <p class="text-brand-text/60 mb-8 max-w-xl mx-auto">
        Мы можем привезти оборудование и корма под заказ или изготовить уникальные 3D-изделия по вашим размерам.
      </p>
      <a 
        href={import.meta.env.PUBLIC_TG_LINK}
        class="inline-block px-10 py-4 bg-brand-text text-brand-bg rounded-xl font-bold transition-transform hover:scale-105 active:scale-95"
      >
        Написать нам
      </a>
    </div>
  </section>

  <SiteFooter slot="footer" />

  <script>
    const tabButtons = document.querySelectorAll('#shop-tabs button');
    const productItems = document.querySelectorAll('.product-item');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const tab = button.getAttribute('data-tab') || 'all';

        // Update UI
        tabButtons.forEach(btn => {
          btn.classList.remove('bg-brand-bg', 'text-brand-text', 'shadow-sm');
          btn.classList.add('text-brand-text/50');
        });
        button.classList.add('bg-brand-bg', 'text-brand-text', 'shadow-sm');
        button.classList.remove('text-brand-text/50');

        // Filter items
        productItems.forEach(item => {
          const type = (item as HTMLElement).dataset.type;
          if (tab === 'all' || type === tab) {
            (item as HTMLElement).style.display = 'block';
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</MainLayout>
