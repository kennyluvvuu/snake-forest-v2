---
import MainLayout from '../../layouts/MainLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import AnimalCard from '../../components/AnimalCard.astro';
import { apiFetch, type Animal } from '@/lib/api.ts';

let animals: Animal[] = [];
let error = null;

try {
  animals = await apiFetch<Animal[]>('/animals/');
} catch (e) {
  console.error("Failed to fetch animals catalog:", e);
  error = "Не удалось загрузить каталог животных";
}

const speciesOptions = [
  { id: 'all', label: 'Все' },
  { id: 'snake', label: 'Змеи' },
  { id: 'lizard', label: 'Ящерицы' },
  { id: 'turtle', label: 'Черепахи' },
  { id: 'rodent', label: 'Грызуны' },
  { id: 'other', label: 'Прочее' }
];
---

<MainLayout title="Каталог животных | Змеиный лес">
  <SiteHeader slot="header" />

  <section class="pt-24 pb-32 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-12">
          <div>
            <h1 class="text-5xl md:text-7xl font-serif font-black text-brand-text mb-4">Наши жители</h1>
            <div class="h-1.5 w-32 bg-brand-accent organic-shape-1"></div>
          </div>
          
          <!-- Tabs -->
          <div class="overflow-x-auto pb-2 scrollbar-hide">
            <div class="flex gap-2 p-1.5 bg-brand-surface rounded-[2rem] border border-brand-border w-max shadow-inner" id="filter-container">
              {speciesOptions.map(option => (
                <button 
                  data-filter={option.id}
                  class={`px-8 py-3 rounded-xl text-xs font-black uppercase tracking-[0.2em] transition-all cursor-pointer ${option.id === 'all' ? 'bg-brand-bg text-brand-text shadow-md' : 'text-brand-text/40 hover:text-brand-text'}`}
                >
                  {option.label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

      {error ? (
        <div class="bg-brand-surface p-20 organic-shape-1 border border-brand-border text-center shadow-inner">
          <p class="text-brand-text/40 italic font-serif text-2xl">{error}</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 md:gap-10" id="animal-grid">
          {animals.length > 0 ? (
            animals.map((animal, i) => (
              <div class="filter-item animate-serpentine" data-species={animal.species.toLowerCase()} style={`animation-delay: ${i * 50}ms`}>
                <AnimalCard animal={animal} />
              </div>
            ))
          ) : (
            <p class="col-span-full text-center text-brand-text/40 py-32 font-serif italic text-3xl">В данный момент каталог пуст</p>
          )}
        </div>
      )}
    </div>
  </section>

  <SiteFooter slot="footer" />

  <script>
    import { initFilter } from '@/scripts/filter.ts';

    initFilter({
      filterContainerSelector: '#filter-container',
      itemSelector: '.filter-item',
      itemDataKey: 'species',
      activeClasses: ['bg-brand-bg', 'text-brand-text', 'shadow-md'],
      inactiveClasses: ['text-brand-text/40'],
    });
  </script>
</MainLayout>
