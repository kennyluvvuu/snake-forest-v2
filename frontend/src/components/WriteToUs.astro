---
const tgLink = import.meta.env.PUBLIC_TG_LINK || 'https://t.me/snakeforest';
const waLink = import.meta.env.PUBLIC_WA_LINK || 'https://wa.me/79991234567';

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`relative group ${className}`}>
  <div class="absolute inset-0 bg-brand-accent/10 rounded-[2.5rem] transform translate-x-4 translate-y-4 -z-10 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform duration-500"></div>
  <div class="bg-brand-surface border border-brand-border p-8 md:p-12 rounded-[2.5rem] h-full flex flex-col justify-center">
    <h3 class="text-3xl font-serif font-bold text-brand-text mb-6">Напишите нам</h3>
    <p class="text-brand-text/60 text-lg mb-8 leading-relaxed">
      У вас есть вопросы о наличии животных или нужна помощь в выборе оборудования? Наши специалисты готовы проконсультировать вас в любое время.
    </p>
    <div class="space-y-4">
      <a href={tgLink} target="_blank" rel="noopener noreferrer" class="flex items-center justify-between p-6 bg-brand-text text-brand-bg rounded-2xl font-bold hover:scale-[1.02] transition-transform">
        Написать в Telegram
        <span>→</span>
      </a>
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="flex items-center justify-between p-6 bg-brand-bg text-brand-text border border-brand-border rounded-2xl font-bold hover:bg-brand-surface transition-colors">
        Написать в WhatsApp
        <span>→</span>
      </a>
    </div>
  </div>
</div>
