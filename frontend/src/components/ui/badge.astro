---
interface Props {
  variant?: 'default' | 'outline';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const base = 'inline-flex items-center px-4 py-1.5 text-[10px] sm:text-[11px] font-black uppercase tracking-[0.2em] transition-all duration-300';
const variants = {
  default: 'bg-brand-text/80 backdrop-blur-md text-brand-bg border border-brand-border/30 organic-shape-2 shadow-sm group-hover:bg-brand-accent group-hover:text-white group-hover:border-transparent',
  outline: 'bg-transparent text-brand-text border border-brand-border organic-shape-1',
};
---

<span class={`${base} ${variants[variant]} ${className}`}>
  <slot />
</span>
