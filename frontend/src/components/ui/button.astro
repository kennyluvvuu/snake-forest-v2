---
interface Props {
  variant?: 'default' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'icon';
  class?: string;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  ariaLabel?: string;
  [key: string]: unknown;
}

const {
  variant = 'default',
  size = 'md',
  class: className = '',
  href,
  type = 'button',
  ariaLabel,
  ...rest
} = Astro.props;

const base = 'inline-flex items-center justify-center font-medium transition-all active:scale-95 rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent';

const variants = {
  default: 'bg-brand-text text-brand-bg hover:bg-brand-accent hover:text-white shadow-sm',
  ghost:   'text-brand-text hover:bg-brand-surface rounded-full',
  outline: 'bg-transparent text-brand-text border border-brand-border hover:bg-brand-surface',
};

const sizes = {
  sm:   'px-4 py-2 text-sm gap-2',
  md:   'px-6 py-3 text-base gap-2',
  icon: 'p-2',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a href={href} class={classes} aria-label={ariaLabel} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} aria-label={ariaLabel} {...rest}>
    <slot />
  </button>
)}
