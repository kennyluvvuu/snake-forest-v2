---
import { Search } from '@lucide/astro';
---

<header class="sticky top-0 z-50 w-full bg-brand-bg/80 backdrop-blur-md border-b border-brand-border px-4 py-4 md:px-8">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <a href="/" class="flex items-center group" aria-label="Snake Forest Home">
      <svg viewBox="0 0 400 60" class="h-10 md:h-12 w-auto fill-brand-text transition-transform group-hover:scale-[1.02]">
        <text x="0" y="45" font-family="'Playfair Display', serif" font-weight="700" font-size="40">
          SNAKE F<tspan dx="-2"> </tspan>REST
        </text>
        <!-- The Eye in O -->
        <g transform="translate(172, 30)">
          <circle cx="0" cy="0" r="18" fill="var(--color-brand-text)" />
          <ellipse cx="0" cy="0" rx="14" ry="10" fill="var(--color-teal-eye)" />
          <path d="M -14 0 Q 0 -12 14 0 Q 0 12 -14 0" fill="none" stroke="var(--color-brand-text)" stroke-width="1.5" />
          <rect x="-1" y="-6" width="2" height="12" rx="1" fill="var(--color-brand-text)" />
        </g>
      </svg>
    </a>

    <div class="flex items-center gap-4">
      <button class="p-2 hover:bg-brand-surface rounded-full transition-colors" aria-label="Search">
        <Search class="w-5 h-5" />
      </button>
    </div>
  </div>
</header>
