---
import { Search, Menu, X } from '@lucide/astro';
import Button from './ui/button.astro';

const navLinks = [
  { name: 'Главная', href: '/' },
  { name: 'Животные', href: '/animals' },
  { name: 'Товары', href: '/shop' },
  { name: 'О нас', href: '/about' },
  { name: 'Контакты', href: '/contacts' },
];
---

<header id="main-header" class="sticky top-0 z-50 w-full bg-brand-bg/80 backdrop-blur-md border-b border-brand-border px-4 py-4 md:px-8">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <a href="/" class="flex items-center group z-50" aria-label="Snake Forest Home">
      <div class="flex flex-col items-start leading-none">
        <span class="text-3xl md:text-4xl font-serif font-black tracking-tighter text-brand-text group-hover:text-brand-accent transition-colors">SF</span>
        <span class="text-[8px] md:text-[10px] font-bold uppercase tracking-[0.4em] text-brand-text/40">Snake Forest</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-10">
      {navLinks.map(link => (
        <a href={link.href} class="text-xs font-bold uppercase tracking-[0.2em] text-brand-text/60 hover:text-brand-text transition-all relative group/nav py-2">
          {link.name}
          <span class="absolute bottom-0 left-0 w-0 h-px bg-brand-accent group-hover/nav:w-full transition-all duration-500"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1 md:gap-2">
      <Button variant="ghost" size="icon" ariaLabel="Поиск">
        <Search class="w-5 h-5" />
      </Button>
      
      <!-- Mobile Menu Toggle -->
      <Button
        id="menu-toggle"
        variant="ghost"
        size="icon"
        class="md:hidden z-50"
        ariaLabel="Открыть меню"
      >
        <Menu id="menu-icon" class="w-6 h-6" />
        <X id="close-icon" class="w-6 h-6 hidden" />
      </Button>
    </div>
  </div>

</header>

<!-- Mobile Menu Overlay -->
<div 
  id="mobile-menu" 
  class="fixed inset-0 bg-brand-bg/60 backdrop-blur-2xl z-40 transform translate-x-full transition-transform duration-500 ease-apple md:hidden"
>
  <div class="flex flex-col h-full pt-24 px-8">
    <nav class="flex flex-col gap-10">
      {navLinks.map((link, index) => (
        <a 
          href={link.href} 
          class="text-5xl md:text-7xl font-serif font-black text-brand-text hover:text-brand-accent transition-all duration-500 opacity-0 transform translate-y-8 nav-link-item group"
          style={`transition-delay: ${index * 70}ms`}
        >
          <span class="inline-block group-hover:translate-x-4 transition-transform duration-500">
            {link.name}
          </span>
        </a>
      ))}
    </nav>
    
    <div class="mt-auto pb-12 opacity-0 transform translate-y-4 menu-footer transition-all duration-500 delay-300">
      <p class="text-brand-text/40 text-sm mb-4 uppercase tracking-widest">Будем на связи</p>
      <div class="flex gap-4">
        <a href="#" class="text-brand-text/60 hover:text-brand-accent">Telegram</a>
        <a href="#" class="text-brand-text/60 hover:text-brand-accent">ВКонтакте</a>
      </div>
    </div>
  </div>
</div>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const body = document.body;
  const navLinks = document.querySelectorAll('.nav-link-item');
  const menuFooter = document.querySelector('.menu-footer');

  function toggleMenu() {
    const isOpen = mobileMenu?.classList.contains('translate-x-0');
    const header = document.querySelector('header');
    
    if (isOpen) {
      mobileMenu?.classList.replace('translate-x-0', 'translate-x-full');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      body.style.overflow = '';
      navLinks.forEach(link => {
        (link as HTMLElement).classList.remove('opacity-100', 'translate-y-0');
        (link as HTMLElement).classList.add('opacity-0', 'translate-y-4');
      });
      menuFooter?.classList.remove('opacity-100', 'translate-y-0');
      menuFooter?.classList.add('opacity-0', 'translate-y-4');
    } else {
      mobileMenu?.classList.replace('translate-x-full', 'translate-x-0');
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      body.style.overflow = 'hidden';
      setTimeout(() => {
        navLinks.forEach(link => {
          (link as HTMLElement).classList.remove('opacity-0', 'translate-y-4');
          (link as HTMLElement).classList.add('opacity-100', 'translate-y-0');
        });
        menuFooter?.classList.remove('opacity-0', 'translate-y-4');
        menuFooter?.classList.add('opacity-100', 'translate-y-0');
      }, 100);
    }
  }

  menuToggle?.addEventListener('click', toggleMenu);

  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu?.classList.contains('translate-x-0')) {
        toggleMenu();
      }
    });
  });
</script>

<style>
  .ease-apple {
    transition-timing-function: cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  #main-header, #mobile-menu {
    -webkit-backdrop-filter: blur(var(--blur-amount, 12px));
  }

  #main-header {
    --blur-amount: 12px;
  }

  #mobile-menu {
    --blur-amount: 40px;
  }

  .backdrop-blur-none {
    -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;
  }
</style>
