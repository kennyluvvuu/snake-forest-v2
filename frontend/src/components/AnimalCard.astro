---
import type { Animal } from '@/lib/api.ts';
import Badge from './ui/badge.astro';
import { ArrowRight } from '@lucide/astro';

interface Props {
  animal: Animal;
  loading?: 'lazy' | 'eager';
}

const { animal, loading = 'lazy' } = Astro.props;

const imageUrl = animal.preview?.[0] || (animal as any).imagesUrl?.[0] || 'https://placehold.co/600x400?text=Animal';

const ageLabels: Record<string, string> = {
  young: 'Малыш',
  adult: 'Взрослый',
  elderly: 'Пожилой'
};
---

<a href={`/animals/${animal.slug}`} class="group block bg-brand-surface organic-shape-1 overflow-hidden border border-brand-border transition-all duration-500 hover:shadow-2xl hover:border-brand-accent/50 relative">
  <div class="aspect-[4/3] overflow-hidden bg-brand-bg relative">
    <img 
      src={imageUrl} 
      alt={animal.commonName}
      loading={loading}
      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 group-hover:rotate-1"
    />
    <!-- Iridescent overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-tr from-teal-eye/20 to-brand-accent/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    
    <div class="absolute top-4 left-4 z-10">
      <Badge class="border-none">{ageLabels[animal.age]}</Badge>
    </div>
  </div>
  
  <div class="p-8 space-y-4">
    <div class="relative">
      <h3 class="text-2xl font-serif font-black text-brand-text group-hover:text-brand-accent transition-colors duration-300 leading-tight">
        {animal.commonName}
      </h3>
      <div class="w-0 group-hover:w-full h-px bg-brand-accent/30 transition-all duration-700 mt-1"></div>
      <p class="text-brand-text/40 text-xs font-bold uppercase tracking-[0.2em] mt-2">
        {animal.morph}
      </p>
    </div>
    
    <div class="flex items-end justify-between pt-4">
      <div class="flex flex-col">
        <span class="text-xs text-brand-text/30 font-bold uppercase tracking-tighter mb-1">Стоимость</span>
        <span class="text-2xl font-black text-brand-text flex items-baseline gap-1">
          {animal.price.toLocaleString('ru-RU')} <span class="text-sm font-light opacity-40">₽</span>
        </span>
      </div>
      
      <div class="w-12 h-12 rounded-full border border-brand-border flex items-center justify-center group-hover:bg-brand-text group-hover:text-brand-bg transition-all duration-500 group-hover:scale-110 group-hover:rotate-45">
        <ArrowRight class="w-5 h-5" />
      </div>
    </div>
  </div>
  
  <!-- Subtle scale pattern overlay -->
  <div class="absolute bottom-0 right-0 w-32 h-32 opacity-[0.03] pointer-events-none group-hover:opacity-[0.07] transition-opacity duration-700" style="background-image: radial-gradient(var(--color-brand-text) 1px, transparent 1px); background-size: 8px 8px;"></div>
</a>
