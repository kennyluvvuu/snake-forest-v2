---
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
}

const { title, description, image, href } = Astro.props;
---

<a href={href} class="group relative aspect-[16/10] rounded-2xl overflow-hidden border border-brand-border">
  <img 
    src={image} 
    alt={title}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-brand-text/90 via-brand-text/40 to-transparent"></div>
  <div class="absolute inset-0 p-6 flex flex-col justify-end">
    <h3 class="text-2xl font-serif font-bold text-brand-bg mb-2 group-hover:text-brand-accent transition-colors">
      {title}
    </h3>
    <p class="text-brand-bg/80 text-sm leading-relaxed max-w-[200px]">
      {description}
    </p>
  </div>
</a>
