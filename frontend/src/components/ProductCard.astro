---
import type { Product } from '@/lib/api.ts';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const imageUrl = product.preview?.[0] || (product as any).imagesUrl?.[0] || 'https://placehold.co/600x400?text=Product';

const typeLabels = {
  toy: 'Игрушка',
  usable: 'Оборудование',
  food: 'Корм'
};
---

<div class="group bg-brand-surface rounded-2xl overflow-hidden border border-brand-border transition-all hover:shadow-xl hover:-translate-y-1">
  <div class="aspect-square overflow-hidden bg-brand-bg relative">
    <img 
      src={imageUrl} 
      alt={product.name}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute top-4 left-4">
      <span class="px-3 py-1 bg-brand-bg/90 backdrop-blur-md text-brand-text text-[10px] sm:text-[9px] md:text-xs font-bold uppercase tracking-widest rounded-full border border-brand-border/50 shadow-sm">
        {typeLabels[product.type]}
      </span>
    </div>
  </div>
  
  <div class="p-6 sm:p-4 md:p-6 space-y-4">
    <h3 class="text-xl sm:text-base md:text-xl font-serif font-bold text-brand-text leading-tight min-h-[3rem] line-clamp-2 group-hover:text-brand-accent transition-colors">
      {product.name}
    </h3>
    
    <div class="flex items-center justify-between pt-4 border-t border-brand-border/30">
      <span class="text-2xl sm:text-lg md:text-2xl font-black text-brand-text">
        {product.price.toLocaleString('ru-RU')} <span class="text-sm font-normal opacity-70">₽</span>
      </span>
      <button class="p-3 sm:p-2 md:p-3 bg-brand-text text-brand-bg hover:bg-brand-accent hover:text-white rounded-xl transition-all shadow-md hover:shadow-lg active:scale-95 group/btn" aria-label="Add to cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 sm:w-5 sm:h-5 md:w-6 md:h-6"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      </button>
    </div>
  </div>
</div>
