---
import type { Product } from '@/lib/api.ts';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const imageUrl = product.preview?.[0] || (product as any).imagesUrl?.[0] || 'https://placehold.co/600x400?text=Product';

const typeLabels = {
  toy: 'Игрушка',
  usable: 'Оборудование',
  food: 'Корм'
};
---

<div class="group bg-brand-surface rounded-2xl overflow-hidden border border-brand-border transition-all hover:shadow-md">
  <div class="aspect-square overflow-hidden bg-brand-bg relative">
    <img 
      src={imageUrl} 
      alt={product.name}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute top-3 left-3">
      <span class="px-2 py-1 bg-brand-bg/80 backdrop-blur-sm text-brand-text text-[10px] font-bold uppercase tracking-widest rounded border border-brand-border/50">
        {typeLabels[product.type]}
      </span>
    </div>
  </div>
  
  <div class="p-4 space-y-3">
    <h3 class="text-lg font-bold text-brand-text leading-tight min-h-[3rem] line-clamp-2">
      {product.name}
    </h3>
    
    <div class="flex items-center justify-between">
      <span class="text-xl font-bold text-brand-accent">
        {product.price.toLocaleString('ru-RU')} ₽
      </span>
      <button class="p-2 bg-brand-bg hover:bg-brand-border/20 rounded-full transition-colors text-brand-text" aria-label="Add to cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      </button>
    </div>
  </div>
</div>
