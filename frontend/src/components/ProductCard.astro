---
import type { Product } from '@/lib/api.ts';
import Badge from './ui/badge.astro';
import { ArrowRight } from '@lucide/astro';

interface Props {
  product: Product;
  loading?: 'lazy' | 'eager';
}

const { product, loading = 'lazy' } = Astro.props;

const imageUrl = product.preview?.[0] || (product as any).imagesUrl?.[0] || 'https://placehold.co/600x400?text=Product';

const typeLabels: Record<string, string> = {
  toy: 'Игрушка',
  usable: 'Оборудование',
  food: 'Корм'
};
---

<a href={`/shop/${product.slug}`} class="group block bg-brand-surface organic-shape-2 overflow-hidden border border-brand-border transition-all duration-500 hover:shadow-2xl hover:border-brand-accent/40 relative">
  <div class="aspect-square overflow-hidden bg-brand-bg relative">
    <img 
      src={imageUrl} 
      alt={product.name}
      loading={loading}
      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
    />
    <div class="absolute top-4 left-4 z-10">
      <Badge class="organic-shape-1">{typeLabels[product.type]}</Badge>
    </div>
  </div>
  
  <div class="p-8 space-y-4">
    <div class="min-h-[4rem]">
      <h3 class="text-xl font-serif font-black text-brand-text group-hover:text-brand-accent transition-colors duration-300 leading-tight line-clamp-2">
        {product.name}
      </h3>
    </div>
    
    <div class="flex items-center justify-between pt-4 border-t border-brand-border/30">
      <span class="text-2xl font-black text-brand-text">
        {product.price.toLocaleString('ru-RU')} <span class="text-sm font-light opacity-40">₽</span>
      </span>
      <div class="w-10 h-10 rounded-full border border-brand-border flex items-center justify-center group-hover:bg-brand-text group-hover:text-brand-bg transition-all duration-500">
        <ArrowRight class="w-4 h-4" />
      </div>
    </div>
  </div>
</a>
