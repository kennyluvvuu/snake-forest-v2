---
import type { Product } from '@/lib/api.ts';
import Badge from './ui/badge.astro';
import { ArrowRight } from '@lucide/astro';

interface Props {
  product: Product;
  loading?: 'lazy' | 'eager';
}

const { product, loading = 'lazy' } = Astro.props;

const imageUrl = product.preview?.[0] || (product as any).imagesUrl?.[0] || 'https://placehold.co/600x400?text=Product';

const typeLabels: Record<string, string> = {
  toy: 'Игрушка',
  usable: 'Оборудование',
  food: 'Корм'
};
---

<a href={`/shop/${product.id}`} class="group block bg-brand-surface rounded-2xl overflow-hidden border border-brand-border transition-all hover:shadow-xl hover:-translate-y-1">
  <div class="aspect-square overflow-hidden bg-brand-bg relative">
    <img 
      src={imageUrl} 
      alt={product.name}
      loading={loading}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
    <div class="absolute top-4 left-4">
      <Badge>{typeLabels[product.type]}</Badge>
    </div>
  </div>
  
  <div class="p-6 sm:p-5 md:p-6 space-y-3">
    <div>
      <h3 class="text-xl sm:text-base md:text-xl font-serif font-bold text-brand-text group-hover:text-brand-accent transition-colors leading-tight min-h-[3rem] line-clamp-2">
        {product.name}
      </h3>
    </div>
    
    <div class="flex items-center justify-between pt-4 border-t border-brand-border/30">
      <span class="text-xl sm:text-lg md:text-xl font-black text-brand-text">
        {product.price.toLocaleString('ru-RU')} <span class="text-sm font-normal opacity-70">₽</span>
      </span>
      <span class="text-sm font-bold text-brand-accent/80 group-hover:text-brand-accent transition-all flex items-center gap-1">
        Смотреть
        <ArrowRight class="w-4 h-4 transition-transform group-hover:translate-x-1" />
      </span>
    </div>
  </div>
</a>
