{
    "name": "backend",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "build-dev": "bun build ./src/index.ts --outdir ./target/dev --sourcemap=inline",
        "build-release": "bun build ./src/index.ts --outdir ./target/release --minify",
        "start": "bun run src/index.ts",
        "dev": "bun run --watch src/index.ts"
    },
    "devDependencies": {
        "@types/bun": "latest"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@types/config": "^3.3.5",
        "@types/mime-types": "^3.0.1",
        "config": "^4.1.1",
        "fastify": "^5.6.2",
        "fastify-plugin": "^5.1.0",
        "fastify-type-provider-zod": "^6.1.0",
        "mime-types": "^3.0.2",
        "mongoose": "^9.0.1",
        "zod": "^4.1.13"
    }
}
